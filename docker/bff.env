ENV=production
ENVIRONMENT=local
LOG_LEVEL=INFO

PORT=8003
REDIS_URL=redis://redis:6379/0

NAVIGATION_SERVICE_URL=http://navigation:8000
POSITIONING_SERVICE_URL=http://positioning:8000
CHATBOT_SERVICE_URL=http://chatbot-service:8002

ALLOWED_HOSTS=*
CORS_ORIGINS=*



# -----------------------------
# 🔥 NAVIGATION RESILIENCE (REAL-TIME, HIGH QPS)
# -----------------------------

NAVIGATION_RESILIENCE_RETRY_MAX_ATTEMPTS=2
NAVIGATION_RESILIENCE_RETRY_DELAY_SECONDS=0.2
NAVIGATION_RESILIENCE_RETRY_BACKOFF_FACTOR=2.0
NAVIGATION_RESILIENCE_RETRY_MAX_DELAY_SECONDS=1

NAVIGATION_RESILIENCE_CIRCUIT_FAILURE_THRESHOLD=5
NAVIGATION_RESILIENCE_CIRCUIT_RECOVERY_TIMEOUT_SECONDS=15
NAVIGATION_RESILIENCE_CIRCUIT_SUCCESS_THRESHOLD=2

NAVIGATION_RESILIENCE_BULKHEAD_MAX_CONCURRENT=60
NAVIGATION_RESILIENCE_BULKHEAD_MAX_WAIT_SECONDS=0

# Admin isolation (CRITICAL)
NAVIGATION_ADMIN_RESILIENCE_BULKHEAD_MAX_CONCURRENT=12


# -----------------------------
# 🧠 POSITIONING RESILIENCE (CPU/IO HEAVY, LOWER QPS)
# -----------------------------

POSITIONING_RESILIENCE_RETRY_MAX_ATTEMPTS=2
POSITIONING_RESILIENCE_RETRY_DELAY_SECONDS=0.6
POSITIONING_RESILIENCE_RETRY_BACKOFF_FACTOR=2.0
POSITIONING_RESILIENCE_RETRY_MAX_DELAY_SECONDS=4

POSITIONING_RESILIENCE_CIRCUIT_FAILURE_THRESHOLD=3
POSITIONING_RESILIENCE_CIRCUIT_RECOVERY_TIMEOUT_SECONDS=45
POSITIONING_RESILIENCE_CIRCUIT_SUCCESS_THRESHOLD=1

POSITIONING_RESILIENCE_BULKHEAD_MAX_CONCURRENT=12
POSITIONING_RESILIENCE_BULKHEAD_MAX_WAIT_SECONDS=0

# Admin isolation
POSITIONING_ADMIN_RESILIENCE_BULKHEAD_MAX_CONCURRENT=4