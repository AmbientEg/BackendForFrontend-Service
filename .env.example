APP_NAME=Backend For Frontend Service
APP_VERSION=0.1.0
ENVIRONMENT=dev
LOG_LEVEL=INFO

BACKEND_API_BASE_URL=http://localhost:9000
NAVIGATION_SERVICE_URL=http://localhost:9010
POSITIONING_SERVICE_URL=http://localhost:9020
