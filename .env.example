# NAVIGATION_RESILIENCE_CIRCUIT_RECOVERY_TIMEOUT_SECONDS=30
# NAVIGATION_RESILIENCE_CIRCUIT_SUCCESS_THRESHOLD=2
# NAVIGATION_RESILIENCE_BULKHEAD_MAX_CONCURRENT=20
# NAVIGATION_RESILIENCE_BULKHEAD_MAX_WAIT_SECONDS=0

# NAVIGATION_ADMIN_RESILIENCE_BULKHEAD_MAX_CONCURRENT=5

