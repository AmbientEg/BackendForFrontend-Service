ENV=development
ENVIRONMENT=local
LOG_LEVEL=INFO

PORT=8003
REDIS_URL=redis://redis-cache:6379

NAVIGATION_SERVICE_URL=http://navigation-service:8000
POSITIONING_SERVICE_URL=http://positioning-service:8001
CHATBOT_SERVICE_URL=http://chatbot-service:8002

ALLOWED_HOSTS=*
CORS_ORIGINS=*

# Legacy compatibility variable (app logic currently uses ENV)
IS_PRODUCTION=false

# Optional resilience overrides
# NAVIGATION_RESILIENCE_RETRY_MAX_ATTEMPTS=3
# NAVIGATION_RESILIENCE_RETRY_DELAY_SECONDS=0.5
