          "  const cid = `postman-${Date.now()}-${Math.floor(Math.random() * 100000)}`;",
          "  pm.request.headers.add({ key: 'X-Correlation-ID', value: cid });",
          "}",
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response time is under 3000ms', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(3000);",
          "});",
          "",
          "pm.test('Content-Type is JSON when body exists', function () {",
          "  if (pm.response.text() && pm.response.text().trim().length > 0) {",
          "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "  }",
          "});",
          ""
        ]
      }
    }
